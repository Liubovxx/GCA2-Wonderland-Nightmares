package domain;

public class Player {
    private int playerId;
    private String name;
    private String nationality;
    private int favoriteCardId;
    private String bestAchievement;
    private int currentRanking;
    private int madnessPoints;

    // Конструктори
    public Player() {}

    public Player(String name, String nationality, String bestAchievement, int currentRanking) {
        this.name = name;
        this.nationality = nationality;
        this.bestAchievement = bestAchievement;
        this.currentRanking = currentRanking;
    }

    // Геттери та сеттери
    public int getPlayerId() { return playerId; }
    public void setPlayerId(int playerId) { this.playerId = playerId; }

    public String getName() { return name; }
    public void setName(String name) { this.name = name; }

    public String getNationality() { return nationality; }
    public void setNationality(String nationality) { this.nationality = nationality; }

    public int getFavoriteCardId() { return favoriteCardId; }
    public void setFavoriteCardId(int favoriteCardId) { this.favoriteCardId = favoriteCardId; }

    public String getBestAchievement() { return bestAchievement; }
    public void setBestAchievement(String bestAchievement) { this.bestAchievement = bestAchievement; }

    public int getCurrentRanking() { return currentRanking; }
    public void setCurrentRanking(int currentRanking) { this.currentRanking = currentRanking; }

    public int getMadnessPoints() { return madnessPoints; }
    public void setMadnessPoints(int madnessPoints) { this.madnessPoints = madnessPoints; }
}
